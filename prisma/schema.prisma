generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

model Sermon {
  id        String   @id @default(cuid())
  category  String   
  title     String
  content   String?  
  videoId   String?  
  date      DateTime @default(now())
}

model News {
  id        String   @id @default(cuid())
  title     String
  content   String
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model WorshipOrder {
  id        String   @id @default(cuid())
  category  String   @unique 
  title     String   
  content   String   
}

model Schedule {
  id        String   @id @default(cuid())
  title     String
  time      String
  place     String
  officer   String
  order     Int      @default(0)
}

model SiteConfig {
  id    String  @id @default(cuid())
  key   String  @unique
  value String
}

// 🛡️ 스텔스 심방 레이더 — 돌봄 필요 성도 감지 DB
model PastoralCare {
  id        String   @id @default(cuid())
  userName  String   // 사용자 이름 (또는 세션 ID)
  reason    String   // 감지된 이유 (예: "우울감 호소", "수술/질병 언급")
  keywords  String?  // 감지된 원문 키워드
  context   String?  // 대화 문맥 (최근 메시지)
  status    String   @default("NEEDS_CARE") // NEEDS_CARE | IN_PROGRESS | COMPLETED
  priority  String   @default("NORMAL")     // URGENT | HIGH | NORMAL
  note      String?  // 관리자 메모
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
}

// 📋 스마트 주보 — AI 이미지 분석 → 자동 등록
model Bulletin {
  id           String   @id @default(cuid())
  date         String            // 주보 날짜 (예: "2026년 4월 27일")
  worshipType  String   @default("주일예배") // 예배 종류
  worshipOrder String            // 예배 순서 (JSON 문자열)
  announcements String?          // 교회 소식/광고 (JSON 문자열)
  prayerPerson String?           // 대표기도자
  hymns        String?           // 찬송가 목록 (JSON 문자열)
  scripture    String?           // 성경 본문
  sermonTitle  String?           // 설교 제목
  offering     String?           // 헌금 안내
  rawText      String?           // AI가 추출한 원문 텍스트
  isActive     Boolean  @default(true) // 현재 활성 주보 여부
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now())
}

// 📖 성경 DB — 개역한글 (GitHub Open Source 기반)
model BibleVerse {
  id        String @id @default(cuid())
  bookKey   String   // 약어 키 (예: "gn", "jo", "ps", "rm")
  bookName  String   // 한글 권명 (예: "창세기", "요한복음", "시편")
  chapter   Int      // 장 번호
  verse     Int      // 절 번호
  text      String   // 절 본문

  @@unique([bookKey, chapter, verse])
  @@index([bookKey, chapter])
  @@index([bookName, chapter])
}

