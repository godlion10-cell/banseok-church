generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

model Sermon {
  id        String   @id @default(cuid())
  category  String   
  title     String
  content   String?  
  videoId   String?  
  date      DateTime @default(now())
}

model News {
  id        String   @id @default(cuid())
  title     String
  content   String
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model WorshipOrder {
  id        String   @id @default(cuid())
  category  String   @unique 
  title     String   
  content   String   
}

model Schedule {
  id        String   @id @default(cuid())
  title     String
  time      String
  place     String
  officer   String
  order     Int      @default(0)
}

model SiteConfig {
  id    String  @id @default(cuid())
  key   String  @unique
  value String
}

// 🛡️ 스텔스 심방 레이더 — 돌봄 필요 성도 감지 DB
model PastoralCare {
  id        String   @id @default(cuid())
  userName  String   // 사용자 이름 (또는 세션 ID)
  reason    String   // 감지된 이유 (예: "우울감 호소", "수술/질병 언급")
  keywords  String?  // 감지된 원문 키워드
  context   String?  // 대화 문맥 (최근 메시지)
  status    String   @default("NEEDS_CARE") // NEEDS_CARE | IN_PROGRESS | COMPLETED
  priority  String   @default("NORMAL")     // URGENT | HIGH | NORMAL
  note      String?  // 관리자 메모
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
}
